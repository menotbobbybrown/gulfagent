# ─────────────────────────────────────────────────────────────────
# GulfAgent — Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── OpenRouter (Single LLM Gateway) ──────────────────────────
# Get from: https://openrouter.ai/keys
# OpenRouter is our only LLM provider — ALL model calls go here
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://gulfagent.com
OPENROUTER_APP_NAME=GulfAgent

# ── Supabase ──────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API
# supabase_url here doubles as the Postgres connection string.
# For SQLAlchemy use: postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL_HTTP=https://[ref].supabase.co   # for Storage + Auth SDK calls
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (keep secret)
SUPABASE_ANON_KEY=eyJ...      # anon key (safe for frontend)

# ── Supabase (Next.js public vars) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Evolution API (WhatsApp) ──────────────────────────────────────
# Self-hosted: https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
WHATSAPP_INSTANCE=gulfagent

# ── Redis (BullMQ) ────────────────────────────────────────────────
# Docker default: redis://redis:6379
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Stripe ────────────────────────────────────────────────────────
# Test mode: https://dashboard.stripe.com/test/apikeys
# AED currency — make sure Stripe account supports AED
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...    # AED 150/mo
STRIPE_PRICE_PRO=price_...      # AED 500/mo

# ── HyperPay (GCC Payment Gateway) ────────────────────────────────
# Get from HyperPay merchant dashboard
HYPERPAY_ENTITY_ID=...
HYPERPAY_ACCESS_TOKEN=...
HYPERPAY_BASE_URL=https://test.oppwa.com

# ── BNPL (Tabby/Tamara) ───────────────────────────────────────────
TABBY_API_KEY=...
TABBY_BASE_URL=https://api.tabby.ai
TAMARA_API_KEY=...
TAMARA_BASE_URL=https://api.tamara.co

# ── E2B Code Sandbox ─────────────────────────────────────────────
E2B_API_KEY=...

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
LANGUAGE_DETECTION_ENABLED=true

# ── Observability (optional) ──────────────────────────────────────
# Langfuse: https://langfuse.com — set keys to enable tracing
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry: https://sentry.io — set DSN to enable error tracking
# SENTRY_DSN=https://...@...ingest.sentry.io/...
